---
import { Picture as AstroPicture } from 'astro:assets';
import type { ComponentProps } from 'astro/types';
import { buildImageConfig } from '@utils/responsive-images';
import type { Layout, Width } from '@utils/responsive-images';

export type { Layout, Width } from '@utils/responsive-images';

type Props = Omit<ComponentProps<typeof AstroPicture>, 'formats' | 'quality'> & {
    pageLayout?: Layout;
    pageWidth?: Width;
    span?: 1 | 2 | 3;
    formats?: ComponentProps<typeof AstroPicture>['formats'];
    quality?: ComponentProps<typeof AstroPicture>['quality'];
    priority?: ComponentProps<typeof AstroPicture>['priority'];
};

const {
    pageLayout = 'one_column',
    pageWidth = 'base',
    span = 1,
    formats = ['avif'],
    quality = 'high',
    priority,
    widths,
    sizes,
    ...rest
} = Astro.props;

const responsiveConfig = buildImageConfig(pageLayout, pageWidth, span);
---

<AstroPicture
    formats={formats}
    quality={quality}
    priority={priority}
    widths={widths ?? responsiveConfig.srcset}
    sizes={sizes ?? `${!priority ? 'auto, ' : ''}${responsiveConfig.sizes}`}
    {...rest as any}
/>
