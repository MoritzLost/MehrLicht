---
import Menu from './Menu.astro'
---

<nav class="mobile-header" aria-label="Main">
    <button class="mobile-header__button button" type="button"
        commandfor="navigation-menu" command="show-modal"
        aria-haspopup="dialog">
        Open menu
    </button>

    <dialog class="navigation-dialog" id="navigation-menu" aria-label="Site navigation">
        <button class="navigation-dialog__close button" type="button"
            commandfor="navigation-menu" command="close">
            Close menu
        </button>
        <Menu layout="mobile" />
    </dialog>
</nav>

<nav class="navigation" aria-label="Main">
    <a href="#content" class="skip-to-content visually-hidden-focusable">Skip to main content</a>
    <Menu layout="desktop" />
</nav>
