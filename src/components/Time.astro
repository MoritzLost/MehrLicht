---
interface Props {
    date: Date;
    class?: string;
}

const { date, class: className } = Astro.props;
---

<time class={className} datetime={date.toISOString().slice(0, 10)}>
    {date.toLocaleDateString('en-GB', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
    })}
</time>
