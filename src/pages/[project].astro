---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import Html from '@layouts/Html.astro';
import PageHeading from '@components/PageHeading.astro';
import BackToTop from '@components/BackToTop.astro';
import { getLightboxImage } from '@utils/lightbox';
import Picture from '@components/Picture.astro';
import { getProjectsCollectionInOrder } from '@utils/collections';

interface Props {
    project: CollectionEntry<'projects'>;
}

export async function getStaticPaths() {
    const projects = await getProjectsCollectionInOrder();
    return projects.map(project => ({
        params: { project: project.id },
        props: { project },
    }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Html
    title={project.data.title}
    image={project.data.image}
    width={project.data.width ?? 'base'}
    themeColor={project.data.themeColor}
>
    <PageHeading heading={project.data.title} date={project.data.date} />

    <hr aria-hidden="true" class="breakout-divider"  style={{ 'margin-bottom': 'var(--article-padding-block)' }} />

    <Content />

    <div class:list={[{
        'one-column': project.data.layout === 'one_column',
        'two-columns': project.data.layout === 'two_columns',
        'three-columns': project.data.layout === 'three_columns',
    }]}>
        {project.data.photos.map (async (photo, index) => {
            const lightbox = await getLightboxImage(photo);
            return <figure>
                <a class="lightbox" aria-label="View full size" href={lightbox.src}>
                    <Picture
                        src={photo}
                        alt=""
                        pageLayout={project.data.layout}
                        pageWidth={project.data.width}
                        priority={index < 3}
                    />
                </a>
            </figure>
        })}
    </div>

    <BackToTop />
</Html>
