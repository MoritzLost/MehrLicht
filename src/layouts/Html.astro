---
import type { ImageMetadata } from 'astro';
import Navigation from '@components/Navigation.astro';
import Footer from '@components/Footer.astro';
import '@styles/main.scss';

import { getLightboxImage } from '@utils/lightbox';

export interface Props {
    title: string;
    description?: string;
    image?: ImageMetadata | string;
    imageAlternativeText?: string;
    themeColor?: string;
    width?: 'base' | 'wide' | 'full';
}

const { title, description, image, imageAlternativeText, themeColor, width } = Astro.props;

let seoImage;
let imageWidth = null;
let imageHeight = null;
if (image) {
    if (typeof image == 'string') {
        seoImage = image;
    } else {
        const optimizedImage = await getLightboxImage(image);
        seoImage = optimizedImage.src;
        imageWidth = optimizedImage.attributes.width;
        imageHeight = optimizedImage.attributes.height;
    }
} else {
    seoImage = null;
}
---

<!DOCTYPE html>
<html lang="en" dir='ltr'>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="color-scheme" content="light dark" />
        <meta name="generator" content={Astro.generator} />

        <title>{ title }</title>
        <meta property="og:site_name" content="Mehr Licht">
        {description && <meta name="description" content={description} />}
        {description && <meta property="og:description" content={description} />}
        {seoImage && <meta property="og:image" content={seoImage} />}
        {imageWidth && <meta property="og:image:width" content={String(imageWidth)} />}
        {imageHeight && <meta property="og:image:height" content={String(imageHeight)} />}
        {seoImage && imageAlternativeText && <meta property="og:image:alt" content={imageAlternativeText} />}

        <script src="../scripts/app.ts"></script>

        <link rel="icon" href="/favicon.svg" type="image/svg+xml">
        <link rel="icon" href="/favicon.ico">
        <link rel="apple-touch-icon" href="/apple-touch-icon.png">
        <link rel="manifest" href="/manifest.json" crossorigin="use-credentials">
        <meta name="theme-color" content="#33607C">
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="alternate" type="application/rss+xml" title="Moritz L'Hoest – Photo Blog" href="/rss.xml" />
    </head>

    <body style={themeColor ? `--theme-color: ${themeColor}` : undefined}>
        <div class={`main main--${width}`}>
            <header class="main__nav">
                <Navigation />
            </header>

            <main class="main__article content" id="content">
                <slot />
            </main>

            <footer class="main__footer footer">
                <Footer />
            </footer>
        </div>
    </body>
</html>
